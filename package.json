{
  "name": "backstage-versions",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "rhdh": "tsx scripts/generate-rhdh-releases.ts",
    "metadata": "tsx scripts/fetch-metadata.ts",
    "tables": "tsx scripts/generate-tables.ts",
    "changes": "tsx scripts/generate-changes.ts",
    "update": "npm run metadata && npm run rhdh && npm run tables && npm run changes",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "semver": "^7.7.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/semver": "^7.7.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
